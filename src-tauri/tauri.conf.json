{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Siege Worlds Launcher",
  "version": "0.1.0",
  "identifier": "io.siegeworlds.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx serve dist -l 1420 --no-clipboard",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Siege Worlds Game Launcher",
    "longDescription": "Launcher for the Siege Worlds game. Downloads, updates, and launches the game with SSO authentication.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Siege Worlds Launcher",
        "width": 960,
        "height": 568,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http: https:"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}
